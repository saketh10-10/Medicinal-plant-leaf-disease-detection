{
  "name": "plant-care-manager",
  "version": "1.0.0",
  "description": "A full-stack plant care management application",
  "scripts": {
    "dev": "node start.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "start": "node start.js",
